generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Owner {
  id                String     @id @default(cuid())
  email             String     @unique
  passwordHash      String
  firstName         String
  lastName          String
  celNum            String?
  street            String?
  barangay          String?
  city              String?
  province          String?
  region            String?
  isActive          Boolean    @default(true)
  isFlagged         Boolean    @default(false)
  flagReason        String?
  profilePictureUrl String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  properties        Property[]

  @@map("owners")
}

model Property {
  id                    String                 @id @default(cuid())
  ownerId               String
  name                  String
  type                  String
  street                String?
  barangay              String?
  city                  String?
  province              String?
  region                String?
  yearBuilt             Int?
  description           String?
  imageUrls             String[]               @default([])
  houseRules            String[]               @default([])
  isActive              Boolean                @default(true)
  isUnderRepair         Boolean                @default(false)
  isUnderRenovation     Boolean                @default(false)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  owner                 Owner                  @relation(fields: [ownerId], references: [id])
  propertyAnnouncements PropertyAnnouncement[]
  units                 Unit[]

  @@map("properties")
}

model Unit {
  id                String             @id @default(cuid())
  propertyId        String
  unitNumber        String
  floor             String?
  bedrooms          Int                @default(0)
  bathrooms         Int                @default(0)
  squareFeet        Float?
  monthlyRentAmount Float
  description       String?
  imageUrls         String[]           @default([])
  features          String[]           @default([])
  status            String             @default("vacant")
  isActive          Boolean            @default(true)
  isUnderRepair     Boolean            @default(false)
  isUnderRenovation Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  leases            Lease[]
  unitAnnouncements UnitAnnouncement[]
  property          Property           @relation(fields: [propertyId], references: [id])

  @@map("units")
}

model Tenant {
  id                String    @id @default(cuid())
  firstName         String
  lastName          String
  email             String    @unique
  celNum            String?
  dateOfBirth       DateTime?
  emergencyName     String?
  emergencyPhone    String?
  notes             String?
  isFlagged         Boolean   @default(false)
  flagReason        String?
  isActive          Boolean   @default(true)
  moveInDate        DateTime?
  moveOutDate       DateTime?
  passwordHash      String?
  inviteToken       String?   @unique
  inviteTokenExpiry DateTime?
  portalEnabled     Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  leases            Lease[]

  @@map("tenants")
}

model Lease {
  id                  String               @id @default(cuid())
  unitId              String
  tenantId            String
  status              String               @default("draft")
  leaseStartDate      DateTime
  leaseEndDate        DateTime
  terms               String?
  notes               String?
  signedAt            DateTime?
  terminatedAt        DateTime?
  terminationReason   String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  documents           LeaseDocument[]
  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  unit                Unit                 @relation(fields: [unitId], references: [id])
  maintenanceRequests MaintenanceRequest[]
  transactions        Transaction[]

  @@map("leases")
}

model Transaction {
  id              String   @id @default(cuid())
  leaseId         String
  amount          Float
  reference       String   @unique
  transactionDate DateTime @default(now())
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lease           Lease    @relation(fields: [leaseId], references: [id])

  @@map("transactions")
}

model Announcement {
  id                    String                 @id @default(cuid())
  title                 String
  body                  String
  isActive              Boolean                @default(true)
  publishedAt           DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  propertyAnnouncements PropertyAnnouncement[]
  unitAnnouncements     UnitAnnouncement[]

  @@map("announcements")
}

model PropertyAnnouncement {
  id             String       @id @default(cuid())
  announcementId String
  propertyId     String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  announcement   Announcement @relation(fields: [announcementId], references: [id])
  property       Property     @relation(fields: [propertyId], references: [id])

  @@map("property_announcements")
}

model UnitAnnouncement {
  id             String       @id @default(cuid())
  announcementId String
  unitId         String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  announcement   Announcement @relation(fields: [announcementId], references: [id])
  unit           Unit         @relation(fields: [unitId], references: [id])

  @@map("unit_announcements")
}

model MaintenanceRequest {
  id                String   @id @default(cuid())
  leaseId           String
  title             String
  description       String
  photoUrl          String?
  permissionToEnter Boolean  @default(false)
  status            String   @default("open")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  lease             Lease    @relation(fields: [leaseId], references: [id])

  @@map("maintenance_requests")
}

model LeaseDocument {
  id        String   @id @default(cuid())
  leaseId   String
  label     String
  url       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lease     Lease    @relation(fields: [leaseId], references: [id])

  @@map("lease_documents")
}
