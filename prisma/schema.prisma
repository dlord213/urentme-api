generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// 1. OWNERS
// ─────────────────────────────────────────────

model Owner {
  id                String   @id @default(cuid())
  email             String   @unique
  passwordHash      String
  firstName         String
  lastName          String
  celNum            String?
  street            String?
  barangay          String?
  city              String?
  province          String?
  region            String?
  isActive          Boolean  @default(true)
  isFlagged         Boolean  @default(false)
  flagReason        String?
  profilePictureUrl String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  properties Property[]

  @@map("owners")
}

// ─────────────────────────────────────────────
// 2. PROPERTIES
// ─────────────────────────────────────────────

model Property {
  id                String   @id @default(cuid())
  ownerId           String
  owner             Owner    @relation(fields: [ownerId], references: [id])
  name              String
  type              String
  street            String?
  barangay          String?
  city              String?
  province          String?
  region            String?
  yearBuilt         Int?
  description       String?
  imageUrls         String[] @default([])
  houseRules        String[] @default([])
  isActive          Boolean  @default(true)
  isUnderRepair     Boolean  @default(false)
  isUnderRenovation Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  units                 Unit[]
  propertyAnnouncements PropertyAnnouncement[]

  @@map("properties")
}

// ─────────────────────────────────────────────
// 3. UNITS
// ─────────────────────────────────────────────

model Unit {
  id                String   @id @default(cuid())
  propertyId        String
  property          Property @relation(fields: [propertyId], references: [id])
  unitNumber        String
  floor             String?
  bedrooms          Int      @default(0)
  bathrooms         Int      @default(0)
  squareFeet        Float?
  monthlyRentAmount Float
  description       String?
  imageUrls         String[] @default([])
  status            String   @default("vacant")
  isActive          Boolean  @default(true)
  isUnderRepair     Boolean  @default(false)
  isUnderRenovation Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  leases            Lease[]
  unitAnnouncements UnitAnnouncement[]

  @@map("units")
}

// ─────────────────────────────────────────────
// 4. TENANTS
// ─────────────────────────────────────────────

model Tenant {
  id                 String    @id @default(cuid())
  firstName          String
  lastName           String
  email              String    @unique
  celNum             String?
  dateOfBirth        DateTime?
  emergencyName      String?
  emergencyPhone     String?
  notes              String?
  isFlagged          Boolean   @default(false)
  flagReason         String?
  isActive           Boolean   @default(true)
  moveInDate         DateTime?
  moveOutDate        DateTime?
  // Portal auth
  passwordHash       String?
  inviteToken        String?   @unique
  inviteTokenExpiry  DateTime?
  portalEnabled      Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  leases               Lease[]

  @@map("tenants")
}

// ─────────────────────────────────────────────
// 5. LEASES
// ─────────────────────────────────────────────

model Lease {
  id                String    @id @default(cuid())
  unitId            String
  unit              Unit      @relation(fields: [unitId], references: [id])
  tenantId          String
  tenant            Tenant    @relation(fields: [tenantId], references: [id])
  status            String    @default("draft")
  leaseStartDate    DateTime
  leaseEndDate      DateTime
  terms             String?
  notes             String?
  signedAt          DateTime?
  terminatedAt      DateTime?
  terminationReason String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  transactions        Transaction[]
  maintenanceRequests MaintenanceRequest[]
  documents           LeaseDocument[]

  @@map("leases")
}

// ─────────────────────────────────────────────
// 6. TRANSACTIONS
// ─────────────────────────────────────────────

model Transaction {
  id              String   @id @default(cuid())
  leaseId         String
  lease           Lease    @relation(fields: [leaseId], references: [id])
  amount          Float
  reference       String   @unique
  transactionDate DateTime @default(now())
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("transactions")
}

// ─────────────────────────────────────────────
// 7. ANNOUNCEMENTS
// ─────────────────────────────────────────────

model Announcement {
  id          String    @id @default(cuid())
  title       String
  body        String
  isActive    Boolean   @default(true)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  propertyAnnouncements PropertyAnnouncement[]
  unitAnnouncements     UnitAnnouncement[]

  @@map("announcements")
}

// ─────────────────────────────────────────────
// 8. PROPERTY ANNOUNCEMENTS (join table)
// ─────────────────────────────────────────────

model PropertyAnnouncement {
  id             String       @id @default(cuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id])
  propertyId     String
  property       Property     @relation(fields: [propertyId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("property_announcements")
}

// ─────────────────────────────────────────────
// 9. UNIT ANNOUNCEMENTS (join table)
// ─────────────────────────────────────────────

model UnitAnnouncement {
  id             String       @id @default(cuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id])
  unitId         String
  unit           Unit         @relation(fields: [unitId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("unit_announcements")
}

// ─────────────────────────────────────────────
// 10. MAINTENANCE REQUESTS
// ─────────────────────────────────────────────

model MaintenanceRequest {
  id               String   @id @default(cuid())
  leaseId          String
  lease            Lease    @relation(fields: [leaseId], references: [id])
  title            String
  description      String
  photoUrl         String?
  permissionToEnter Boolean @default(false)
  status           String   @default("open")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("maintenance_requests")
}

// ─────────────────────────────────────────────
// 11. LEASE DOCUMENTS
// ─────────────────────────────────────────────

model LeaseDocument {
  id        String   @id @default(cuid())
  leaseId   String
  lease     Lease    @relation(fields: [leaseId], references: [id])
  label     String
  url       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("lease_documents")
}
